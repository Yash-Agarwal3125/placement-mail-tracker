APP_ENV=development
LOG_LEVEL=INFO

# SQLite
DATABASE_URL=sqlite:///data/placement_mail_tracker.db

# Gmail API
GMAIL_CREDENTIALS_FILE=config/credentials.json
GMAIL_TOKEN_FILE=config/token.json
GMAIL_QUERY=newer_than:7d
GMAIL_MAX_RESULTS=10

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=1.0

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_RANGE=Sheet1!A1
GOOGLE_SHEET_NAME=Opportunities
GOOGLE_SHEETS_CREDENTIALS_FILE=config/credentials.json
GOOGLE_SHEETS_TOKEN_FILE=config/sheets_token.json

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email SMTP notifications
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
EMAIL_RECEIVER=receiver@example.com

# Scheduler
SYNC_INTERVAL_HOURS=3
